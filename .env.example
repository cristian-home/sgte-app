APP_NAME=SGTE
APP_TAGLINE="Sistema de Gestión de Transporte Especial"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Mirror APP_DEBUG into the Vite client bundle so the browser-side
# debug helper (resources/js/lib/debug-log.ts) gates console.debug
# behind the same flag the server uses for config('app.debug'). Flip
# APP_DEBUG=false in production to silence both at once.
VITE_APP_DEBUG="${APP_DEBUG}"
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

SAIL_XDEBUG_MODE=develop,debug,coverage
SAIL_XDEBUG_PORT=9003

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sail devcontainer ships PostgreSQL 18 (see compose.yaml). The default
# values below match the `pgsql` service. Switch to `DB_CONNECTION=sqlite`
# only for a host-only checkout without Sail.
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=sgte
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3-compatible storage. The Sail devcontainer points at the local
# MinIO container (`minio:9000`) so uploads land in the `local` bucket
# served at http://localhost:9000/local. Production swaps these for the
# real S3 (or any other S3-compatible) credentials. The same AWS_*
# credentials are reused by the `backups` disk for the on-VPS backup
# copy — see the backup section at the bottom of this file.
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/local
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

SCOUT_DRIVER=typesense
SCOUT_QUEUE=true

# Typesense — full-text search backend for Scout. The Sail devcontainer
# ships a `typesense` service; production wires its own host. API key
# is a shared secret between the app and the typesense node — change
# it in compose.yaml + this file together.
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=xyz

WWWGROUP=1000
WWWUSER=1000

REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MEDIA_DISK=media

# Observability — disabled by default so Pulse / Telescope / Nightwatch /
# Debugbar do not register routes or middleware. Enable individually
# for local debugging; keep `false` in production.
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
DEBUGBAR_ENABLED=false

# Octane application server (production: frankenphp). Local dev does
# not run Octane; this only matters when `php artisan octane:start`
# is invoked or the production image boots.
OCTANE_SERVER=frankenphp

SUPER_ADMIN_USER="superadmin@example.com"
SUPER_ADMIN_PASSWORD="password"

# Feature flags — REQ-007 FUEC module exposes /fuecs, /fuec-number-ranges,
# and the public /fuec/verify/{uuid} verification endpoint.
SGTE_FUEC_ENABLED=true
# GPS module (REQ-010) — vehicle location tracking + admin map at /gps/map.
SGTE_GPS_ENABLED=true

# Operation TZ — pin to UTC by default so the date-sensitive tests
# (`Carbon::today()` matches `Carbon::now(config('app.operation_tz'))`)
# pass in CI. Real installs override to America/Bogota in their own .env.
OPERATION_TZ=UTC

# Google Maps Platform — powers address autocomplete, geocoding,
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_MAP_ID=
VITE_GOOGLE_MAPS_BROWSER_KEY="${GOOGLE_MAPS_BROWSER_KEY}"
VITE_GOOGLE_MAPS_MAP_ID="${GOOGLE_MAPS_MAP_ID}"

# Database backups (spatie/laravel-backup) — see docs/deployment.md.
# BACKUP_ARCHIVE_PASSWORD encrypts every archive (AES-256). Store it AND the
# production APP_KEY in a password manager, off the VPS — without them a
# backup cannot be restored after a catastrophic loss.
BACKUP_ARCHIVE_PASSWORD=
# Where backup failure / unhealthy-backup alerts are emailed.
BACKUP_NOTIFICATION_MAIL=
# On-VPS copy — a dedicated bucket on the local S3-compatible store
# (typically MinIO). Create it before the first run. Credentials are
# reused from the AWS_* block above.
BACKUP_LOCAL_BUCKET=sgte-backups
# Off-site copy — any S3-compatible bucket (AWS S3, MinIO, Cloudflare
# R2, Backblaze B2, …). See docs/deployment.md for endpoint examples.
# Region defaults to "auto" (required by R2; AWS S3 needs a real region
# like us-east-1 — uncomment BACKUP_S3_REGION below to override).
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
# BACKUP_S3_REGION=auto

# Dokploy deploy API (staging VPS). Required only to trigger manual
# redeploys from this checkout via `.github/workflows/deploy-staging.yml`
# or a `curl` against Dokploy's `application.redeploy` endpoint.
# ⚠️ NEVER commit real values — these grant deploy access to the VPS.
# Copy the values from the Dokploy panel into your local .env (gitignored).
DOKPLOY_URL=
DOKPLOY_TOKEN=
DOKPLOY_PROJECT_ID=
DOKPLOY_ENVIRONMENT_ID=
DOKPLOY_APP_ID=
