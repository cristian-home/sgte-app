APP_NAME=SGTE
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://laravel.test

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=testing
DB_USERNAME=sail
DB_PASSWORD=password

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
MAIL_MAILER=array
SCOUT_DRIVER=collection
SCOUT_QUEUE=false

BROADCAST_CONNECTION=null
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
DEBUGBAR_ENABLED=false

SUPER_ADMIN_USER="superadmin@example.com"
SUPER_ADMIN_PASSWORD="password"

# Feature flags — on for Dusk so FUEC + GPS routes are reachable.
SGTE_FUEC_ENABLED=true
SGTE_GPS_ENABLED=true
